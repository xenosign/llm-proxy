OPENAI_API_KEY=sk-...
LITELLM_MASTER_KEY=sk...
DATABASE_URL=postgresql

# 가상 키를 발급할 팀 이름 목록 (쉼표 구분)
TEAMS=team_a,team_b,team_c,team_d
# 위 TEAMS와 같은 순서로 매칭되는 팀별 예산(USD)/분당 요청수/분당 토큰수. 개수가 모자라면 각각 MAX_BUDGET/RPM_LIMIT/TPM_LIMIT 기본값 사용
TEAM_BUDGETS=50,50,50,50
TEAM_RPM_LIMITS=20,20,20,20
TEAM_TPM_LIMITS=100000,100000,100000,100000
# TEAM_BUDGETS/TEAM_RPM_LIMITS/TEAM_TPM_LIMITS에 값이 없는 팀에 적용되는 기본값
MAX_BUDGET=50
RPM_LIMIT=20
TPM_LIMIT=100000
